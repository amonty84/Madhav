# Supabase — get from Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Google Gemini — get from aistudio.google.com/app/apikey
# Required when a user picks any Gemini model from the picker. Missing key
# surfaces as a classified auth error in the chat UI, not a crash.
GOOGLE_GENERATIVE_AI_API_KEY=

# DeepSeek — get from platform.deepseek.com/api_keys
# Required when a user picks DeepSeek V3 or R1 from the picker.
DEEPSEEK_API_KEY=

# Astrologer bootstrap — the email that gets 'astrologer' role on first signup
ASTROLOGER_EMAIL=mail.abhisek.mohanty@gmail.com

# Python sidecar — Railway deployment URL
PYTHON_SIDECAR_URL=https://your-sidecar.up.railway.app
PYTHON_SIDECAR_API_KEY=your-random-secret-key
