# Cloud SQL (PostgreSQL on GCP)
# Local dev: run Cloud SQL Auth Proxy, set DATABASE_URL.
# Production (Cloud Run / ADC): set INSTANCE_CONNECTION_NAME + DB_USER/DB_PASSWORD/DB_NAME instead.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/amjis  # local dev via auth proxy
INSTANCE_CONNECTION_NAME=<project-id>:<region>:<instance-id>       # prod only
DB_USER=<db-user>                                                    # prod only
DB_PASSWORD=<db-password>                                            # prod only
DB_NAME=<db-name>                                                    # prod only
GCP_PROJECT=<gcp-project-id>

# Firebase client (public — safe to expose, baked into image at build)
# Get from Firebase Console → Project Settings → General → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=<api-key>
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=<project-id>.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=<project-id>
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=<project-id>.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=<sender-id>
NEXT_PUBLIC_FIREBASE_APP_ID=<app-id>

# Firebase admin (server-side — use Secret Manager in production)
# Service-account JSON collapsed to a single line
FIREBASE_ADMIN_CREDENTIALS=<service-account-json-as-single-line>

# AI providers
# Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=<anthropic-key>
# Google Gemini — aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=<google-key>
# DeepSeek — platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=<deepseek-key>
# OpenAI — platform.openai.com/api-keys
OPENAI_API_KEY=<openai-key>

# Python sidecar (Cloud Run service URL + shared secret)
PYTHON_SIDECAR_URL=http://localhost:8000
PYTHON_SIDECAR_API_KEY=<sidecar-api-key>
# Sidecar CORS — comma-separated allowed origins. In prod set to the frontend Cloud Run URL.
SIDECAR_ALLOWED_ORIGINS=http://localhost:3000

# Super-admin bootstrap — email that gets 'super_admin' role on first signup
SUPER_ADMIN_EMAIL=<super-admin-email>

# Vertex AI / GCP region
VERTEX_AI_LOCATION=asia-south1

# Pipeline (python-sidecar/pipeline/main.py) — Cloud Run Job environment
GCS_SOURCES_BUCKET=madhav-marsys-sources
GCS_ARTIFACTS_BUCKET=madhav-marsys-build-artifacts
PIPELINE_WORKSPACE_ROOT=/app
PIPELINE_IMAGE_URI=asia-south1-docker.pkg.dev/<project-id>/marsys-pipeline/pipeline:latest

# Feature flags — override defaults via MARSYS_FLAG_<FLAG_NAME>=true|false
# Phase 11A cutover (2026-04-28): the new query pipeline and audit logging are now
# DEFAULT ON. To revert to legacy behavior, set the two flags below to false.
# All other flags remain default OFF; flip individually after observation.
#
# MARSYS_FLAG_NEW_QUERY_PIPELINE_ENABLED=false   # uncomment to revert to legacy path
# MARSYS_FLAG_AUDIT_ENABLED=false                # uncomment to disable audit logging
