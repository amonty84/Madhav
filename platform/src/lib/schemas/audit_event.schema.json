{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marsys-jis/schemas/audit_event.schema.json",
  "title": "AuditEvent",
  "description": "Complete execution record per query for the MARSYS-JIS audit trail (C4.1)",
  "version": "1.0",
  "type": "object",
  "required": ["event_id", "timestamp", "conversation_id", "message_id", "user_id", "audience_tier", "query_plan", "manifest_fingerprint", "bundle_id", "bundle_hash", "retrieval_transcripts", "validator_votes", "synthesis_prompt_version", "llm_calls", "semantic_gate_result", "response_text", "total_cost_estimate_usd", "total_latency_ms", "schema_version"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "timestamp": { "type": "string", "format": "date-time" },
    "conversation_id": { "type": "string", "format": "uuid" },
    "message_id": { "type": "string" },
    "user_id": { "type": "string" },
    "audience_tier": { "type": "string", "enum": ["super_admin", "acharya_reviewer", "client", "public_redacted"] },
    "query_plan": { "type": "object" },
    "manifest_fingerprint": { "type": "string" },
    "bundle_id": { "type": "string", "format": "uuid" },
    "bundle_hash": { "type": "string" },
    "retrieval_transcripts": { "type": "array", "items": { "type": "object" } },
    "validator_votes": { "type": "object" },
    "synthesis_prompt_version": { "type": "string" },
    "llm_calls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["call_type", "model_id", "tokens", "latency_ms", "cost_estimate_usd"],
        "properties": {
          "call_type": { "type": "string", "enum": ["router", "augmenter", "reranker", "synthesizer", "panel_member", "adjudicator", "classifier", "discipline_gate"] },
          "model_id": { "type": "string" },
          "tokens": {
            "type": "object",
            "required": ["input", "output"],
            "properties": {
              "input": { "type": "integer", "minimum": 0 },
              "output": { "type": "integer", "minimum": 0 },
              "cached": { "type": "integer", "minimum": 0 }
            }
          },
          "latency_ms": { "type": "integer", "minimum": 0 },
          "cost_estimate_usd": { "type": "number", "minimum": 0 }
        }
      }
    },
    "panel_metadata": { "type": "object" },
    "semantic_gate_result": { "type": "string", "enum": ["pass", "fail"] },
    "semantic_gate_reason": { "type": "string" },
    "response_text": { "type": "string" },
    "total_cost_estimate_usd": { "type": "number", "minimum": 0 },
    "total_latency_ms": { "type": "integer", "minimum": 0 },
    "schema_version": { "type": "string", "const": "1.0" }
  },
  "additionalProperties": false
}
