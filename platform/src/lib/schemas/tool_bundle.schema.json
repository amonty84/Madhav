{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marsys-jis/schemas/tool_bundle.schema.json",
  "title": "ToolBundle",
  "description": "Output of a single retrieval tool invocation in the MARSYS-JIS pipeline",
  "version": "1.0",
  "type": "object",
  "required": ["tool_bundle_id", "tool_name", "tool_version", "invocation_params", "results", "served_from_cache", "latency_ms", "result_hash", "schema_version"],
  "properties": {
    "tool_bundle_id": { "type": "string", "format": "uuid" },
    "tool_name": { "type": "string" },
    "tool_version": { "type": "string" },
    "invocation_params": { "type": "object" },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["content"],
        "properties": {
          "content": { "type": "string" },
          "source_canonical_id": { "type": "string" },
          "source_version": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "significance": { "type": "number", "minimum": 0, "maximum": 1 },
          "signal_id": { "type": "string" }
        }
      }
    },
    "served_from_cache": { "type": "boolean" },
    "latency_ms": { "type": "integer", "minimum": 0 },
    "result_hash": { "type": "string" },
    "schema_version": { "type": "string", "const": "1.0" },
    "cache_key": { "type": "string" }
  },
  "additionalProperties": false
}
