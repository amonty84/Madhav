{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marsys-jis/schemas/panel_metadata.schema.json",
  "title": "PanelMetadata",
  "description": "Panel synthesis metadata recorded in the audit trail when panel_mode is used",
  "version": "1.0",
  "type": "object",
  "required": ["panel_composition", "merged_super_bundle", "panel_responses", "anonymization", "adjudicator_synthesis", "divergence_classification", "panel_total_cost_estimate_usd", "panel_total_latency_ms"],
  "properties": {
    "panel_composition": {
      "type": "object",
      "required": ["adjudicator_model_id", "member_model_ids", "slate_version", "resolver_rule"],
      "properties": {
        "adjudicator_model_id": { "type": "string" },
        "member_model_ids": { "type": "array", "items": { "type": "string" }, "minItems": 3, "maxItems": 3 },
        "slate_version": { "type": "string" },
        "resolver_rule": { "type": "string" },
        "degrade_flags": { "type": "object" },
        "history_mode": { "type": "string", "enum": ["synthesized", "research"] }
      }
    },
    "merged_super_bundle": {
      "type": "object",
      "required": ["baseline_hash", "super_hash", "dedup_count"],
      "properties": {
        "baseline_hash": { "type": "string" },
        "extensions_per_member": { "type": "array", "items": { "type": "object" } },
        "super_hash": { "type": "string" },
        "dedup_count": { "type": "integer", "minimum": 0 }
      }
    },
    "panel_responses": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["member_label", "response_text", "tokens", "latency_ms", "finish_reason"],
        "properties": {
          "member_label": { "type": "string", "enum": ["A", "B", "C"] },
          "response_text": { "type": "string" },
          "tool_calls": { "type": "array", "items": { "type": "object" } },
          "tokens": { "type": "object" },
          "latency_ms": { "type": "integer", "minimum": 0 },
          "finish_reason": { "type": "string" },
          "validator_votes": { "type": "object" },
          "extracted_predictions": { "type": "array", "items": { "type": "object" } },
          "retry_attempts": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "anonymization": {
      "type": "object",
      "required": ["label_to_model", "presentation_order"],
      "properties": {
        "label_to_model": { "type": "object" },
        "presentation_order": { "type": "array", "items": { "type": "string" } }
      }
    },
    "adjudicator_synthesis": {
      "type": "object",
      "required": ["response_text", "tokens", "latency_ms"],
      "properties": {
        "response_text": { "type": "string" },
        "reasoning": { "type": "string" },
        "interpretations_consolidated": { "type": "array", "items": { "type": "string" } },
        "tokens": { "type": "object" },
        "latency_ms": { "type": "integer", "minimum": 0 }
      }
    },
    "divergence_classification": {
      "type": "object",
      "required": ["classifier_model", "tokens", "latency_ms", "divergences"],
      "properties": {
        "classifier_model": { "type": "string" },
        "tokens": { "type": "object" },
        "latency_ms": { "type": "integer", "minimum": 0 },
        "divergences": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["class", "description"],
            "properties": {
              "class": { "type": "string" },
              "description": { "type": "string" },
              "members_involved": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "panel_total_cost_estimate_usd": { "type": "number", "minimum": 0 },
    "panel_total_latency_ms": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
