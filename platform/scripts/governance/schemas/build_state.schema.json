{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://marsys-jis.example/schemas/build_state.schema.json",
  "title": "MARSYS-JIS Build State v0.2.0",
  "description": "v0.2.0 snapshot of project build state. Extends v0.1.0 additively with macro_arc, sub_phases, scripts_trend, sessions_index, phases_index, red_team_passes, staleness_register, cowork_ledger, workstreams, current_brief. Consumed by madhav.marsys.in/build portal via GCS HTTPS fetch. Produced by serialize_build_state.py v0.2.0.",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "generated_by_session",
    "generator_version",
    "source_fingerprints",
    "macro_phase",
    "phase_plan",
    "governance",
    "last_session",
    "next_session",
    "native_directives",
    "canonical_artifacts",
    "mirror_pairs",
    "recent_sessions",
    "disagreement_register",
    "red_team_passes",
    "staleness_register",
    "sessions_index",
    "phases_index",
    "cowork_ledger",
    "workstreams"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Semver of this JSON schema.",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-z0-9.-]+)?$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "generated_by_session": {
      "type": "string"
    },
    "generator_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-z0-9.-]+)?$"
    },
    "source_fingerprints": {
      "type": "object",
      "required": ["current_state", "canonical_artifacts", "session_log", "ongoing_hygiene_policies"],
      "properties": {
        "current_state": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "canonical_artifacts": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "session_log": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "ongoing_hygiene_policies": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "macro_phase": {
      "type": "object",
      "required": ["id", "title", "status"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["active", "paused_governance_rebuild", "paused_native_hold", "closed"]
        },
        "macro_arc": {
          "type": "array",
          "description": "M1–M10 arc entries parsed from MACRO_PLAN_v2_0.md.",
          "items": {
            "type": "object",
            "required": ["id", "title", "status"],
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "status": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "phase_plan": {
      "type": "object",
      "required": ["path", "version", "sub_phase", "status"],
      "properties": {
        "path": { "type": "string" },
        "version": { "type": "string" },
        "sub_phase": { "type": "string" },
        "status": { "type": "string" },
        "sub_phases": {
          "type": "array",
          "description": "B.0–B.10 sub-phase entries from PHASE_B_PLAN.",
          "items": {
            "type": "object",
            "required": ["phase_id", "title", "status"],
            "properties": {
              "phase_id": { "type": "string" },
              "title": { "type": "string" },
              "status": { "type": "string" },
              "session_count_actual": { "type": ["integer", "null"] }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "governance": {
      "type": "object",
      "required": ["rebuild_status", "baseline_artifact_path", "active_step", "active_step_status", "next_step", "next_quarterly_pass", "red_team"],
      "properties": {
        "rebuild_status": { "type": "string", "enum": ["closed", "active"] },
        "baseline_artifact_path": { "type": ["string", "null"] },
        "baseline_closed_on": { "type": ["string", "null"] },
        "active_step": { "type": ["string", "null"] },
        "active_step_status": { "type": ["string", "null"] },
        "next_step": { "type": ["string", "null"] },
        "next_quarterly_pass": { "type": ["string", "null"] },
        "red_team": {
          "type": "object",
          "required": ["counter", "threshold", "due"],
          "properties": {
            "counter": { "type": "integer", "minimum": 0 },
            "threshold": { "type": "integer", "minimum": 1 },
            "due": { "type": "boolean" },
            "note": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        },
        "scripts_trend": {
          "type": "object",
          "description": "Trend arrays for each governance script (last N reports).",
          "properties": {
            "drift_detector": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "report_file": { "type": "string" },
                  "session_id": { "type": ["string", "null"] },
                  "run_at": { "type": ["string", "null"] },
                  "exit_code": { "type": ["integer", "null"] },
                  "finding_count": { "type": ["integer", "null"] }
                },
                "additionalProperties": true
              }
            },
            "schema_validator": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "mirror_enforcer": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "last_session": {
      "type": "object",
      "required": ["id", "closed_at"],
      "properties": {
        "id": { "type": "string" },
        "closed_at": { "type": "string", "format": "date-time" },
        "agent": { "type": ["string", "null"] },
        "cowork_thread_name": { "type": ["string", "null"] },
        "close_state": { "type": ["string", "null"] },
        "drift_verdict": { "type": ["string", "null"] },
        "deliverable_summary": { "type": ["string", "null"] },
        "previous_session_id": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "next_session": {
      "type": "object",
      "required": ["objective"],
      "properties": {
        "objective": { "type": "string" },
        "proposed_cowork_thread_name": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "native_directives": {
      "type": "object",
      "required": ["open", "addressed"],
      "properties": {
        "open": {
          "type": "array",
          "items": { "type": "string", "pattern": "^ND\\.[0-9]+$" }
        },
        "addressed": {
          "type": "array",
          "items": { "type": "string", "pattern": "^ND\\.[0-9]+$" }
        },
        "note": { "type": ["string", "null"] },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["nd_id", "title", "status"],
            "properties": {
              "nd_id": { "type": "string" },
              "title": { "type": "string" },
              "status": { "type": "string" },
              "issued_on": { "type": ["string", "null"] },
              "addressed_on": { "type": ["string", "null"] }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    },
    "disagreement_register": {
      "type": "object",
      "required": ["open_count", "resolved_count", "entries"],
      "properties": {
        "open_count": { "type": "integer", "minimum": 0 },
        "resolved_count": { "type": "integer", "minimum": 0 },
        "entries": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        }
      },
      "additionalProperties": false
    },
    "canonical_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["canonical_id", "path", "version", "status"],
        "properties": {
          "canonical_id": { "type": "string" },
          "path": { "type": "string" },
          "version": { "type": "string" },
          "status": { "type": "string" },
          "fingerprint_sha256": { "type": ["string", "null"] },
          "last_verified_session": { "type": ["string", "null"] },
          "last_verified_on": { "type": ["string", "null"] },
          "mirror_pair_id": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "mirror_pairs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pair_id", "mirror_mode", "authoritative_side"],
        "properties": {
          "pair_id": { "type": "string", "pattern": "^MP\\.[0-9]+$" },
          "claude_side": { "type": ["string", "null"] },
          "gemini_side": { "type": ["string", "null"] },
          "authoritative_side": { "type": "string" },
          "mirror_mode": { "type": "string" },
          "last_verified_session": { "type": ["string", "null"] },
          "days_since_verified": { "type": ["integer", "null"] }
        },
        "additionalProperties": false
      }
    },
    "recent_sessions": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "closed_on": { "type": ["string", "null"] },
          "summary": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "red_team_passes": {
      "type": "array",
      "description": "Parsed from verification_artifacts/RAG/RED_TEAM_*.md.",
      "items": {
        "type": "object",
        "properties": {
          "session_id": { "type": ["string", "null"] },
          "report_path": { "type": "string" },
          "verdict": { "type": "string" },
          "finding_count": { "type": "integer" },
          "residuals": { "type": "array", "items": { "type": "string" } },
          "performed_on": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    },
    "staleness_register": {
      "type": "array",
      "description": "Parsed from STALENESS_REGISTER.md.",
      "items": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "since": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "current_brief": {
      "type": ["object", "null"],
      "description": "Parsed from CLAUDECODE_BRIEF.md at repo root; null if absent or COMPLETE.",
      "properties": {
        "session_id": { "type": "string" },
        "status": { "type": "string" },
        "ac_total": { "type": "integer" },
        "ac_passed_known": { "type": "integer" },
        "may_touch_summary": { "type": "array", "items": { "type": "string" } },
        "must_not_touch_summary": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "staleness_seconds_since_last_close": {
      "type": ["integer", "null"],
      "description": "Seconds since last_session.closed_at. Rendered as human-readable staleness in cockpit header."
    },
    "sessions_index": {
      "type": "array",
      "description": "One row per session in SESSION_LOG.md (legacy + schema-conformant).",
      "items": {
        "type": "object",
        "required": ["session_id", "title"],
        "properties": {
          "session_id": { "type": "string" },
          "title": { "type": "string" },
          "date": { "type": ["string", "null"] },
          "class": { "type": ["string", "null"] },
          "phase_id": { "type": ["string", "null"] },
          "drift_exit": { "type": ["integer", "null"] },
          "schema_exit": { "type": ["integer", "null"] },
          "mirror_exit": { "type": ["integer", "null"] },
          "deliverable_one_liner": { "type": ["string", "null"] },
          "detail_shard": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "phases_index": {
      "type": "array",
      "description": "One row per phase_id observed in sessions_index.",
      "items": {
        "type": "object",
        "required": ["phase_id"],
        "properties": {
          "phase_id": { "type": "string" },
          "detail_shard": { "type": "string" },
          "status": { "type": "string" },
          "session_count": { "type": "integer" }
        },
        "additionalProperties": true
      }
    },
    "cowork_ledger": {
      "type": "array",
      "description": "Entries from COWORK_LEDGER.md; empty array if file absent.",
      "items": {
        "type": "object",
        "properties": {
          "thread_name": { "type": ["string", "null"] },
          "opened_on": { "type": ["string", "null"] },
          "closed_on": { "type": ["string", "null"] },
          "purpose": { "type": ["string", "null"] },
          "outcomes": { "type": "array", "items": { "type": "string" } },
          "spawned_sessions": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "workstreams": {
      "type": "array",
      "description": "Hard-coded for v0.1; promoted to WORKSTREAMS.md canonical file in v0.2.",
      "items": {
        "type": "object",
        "required": ["id", "title", "status"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "status": { "type": "string" },
          "last_activity": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    }
  }
}
