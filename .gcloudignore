# .gcloudignore — excludes large/unnecessary dirs from Cloud Build tarball upload
# Cloud Build runs npm install itself inside the Docker build, so node_modules
# must not be uploaded. This file must live at the repo root because
# `gcloud builds submit` is run from the repo root.

.git
.gitignore
node_modules/
platform/node_modules/
platform/.next/
platform/.turbo/
platform/out/
platform/dist/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.env
.env.*
platform/.env
platform/.env.*
platform/supabase/.temp/
Assets/
platform/python-sidecar/venv/
