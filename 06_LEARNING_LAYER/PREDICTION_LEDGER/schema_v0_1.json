{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "prediction_schema_v0_1",
  "version": "0.1",
  "title": "MARSYS-JIS Prediction Ledger Entry Schema v0.1",
  "produced_at": "2026-04-24",
  "produced_by_session": "Madhav_17_B0",
  "type": "object",
  "required": [
    "prediction_id", "artifact_id", "artifact_type", "claim_text",
    "domain", "verification_window_start", "verification_window_end",
    "falsifier_conditions", "confirmation_conditions",
    "created_at", "created_by_event_id", "ledger_ref",
    "confidence_at_creation"
  ],
  "properties": {
    "prediction_id": {"type": "string", "pattern": "^PRED\\.\\d{3}$"},
    "artifact_id": {"type": "string"},
    "artifact_type": {"type": "string", "enum": ["pattern", "resonance", "cluster", "contradiction"]},
    "claim_text": {"type": "string", "minLength": 10},
    "domain": {"type": "string", "enum": ["career", "wealth", "health", "relationships", "children", "spiritual", "parents", "mind", "travel", "meta"]},
    "verification_window_start": {"type": "string", "format": "date"},
    "verification_window_end": {"type": "string", "format": "date"},
    "falsifier_conditions": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "confirmation_conditions": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "outcome": {"type": ["string", "null"]},
    "outcome_source": {"type": ["string", "null"]},
    "outcome_recorded_at": {"type": ["string", "null"]},
    "created_at": {"type": "string"},
    "created_by_event_id": {"type": "string"},
    "ledger_ref": {"type": "string"},
    "classical_basis": {"type": ["string", "null"]},
    "confidence_at_creation": {"type": "string", "enum": ["LOW", "MED", "HIGH"]},
    "dependencies": {"type": "array", "items": {"type": "string"}}
  }
}
