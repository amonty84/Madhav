# AM-JIS RAG Environment Variables — Example
# Copy to .env.rag and fill in real values
# NEVER commit .env.rag to git (add to .gitignore if not already present)

# Vertex AI Embeddings (primary — text-multilingual-embedding-002, 768 dims)
# Uses Application Default Credentials (ADC) — no API key required.
# Ensure: gcloud auth application-default login (dev) or Workload Identity (prod).
GCP_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1

# Anthropic (Claude — reconciler, synthesizer, router)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (fallback embeddings at index time only — NOT at query time)
OPENAI_API_KEY=your_openai_api_key_here

# Cloud SQL (PostgreSQL on GCP — via Cloud SQL Auth Proxy in dev, ADC in prod)
# Local dev: run auth proxy, then set DATABASE_URL.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/amjis

# Optional: override default model identifiers
# RAG_EMBEDDING_MODEL=text-multilingual-embedding-002
# RAG_RECONCILER_MODEL=claude-opus-4-6
# RAG_ROUTER_MODEL=claude-opus-4-6
# RAG_SYNTHESIZER_MODEL=claude-opus-4-6
