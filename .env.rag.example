# AM-JIS RAG Environment Variables — Example
# Copy to .env.rag and fill in real values
# NEVER commit .env.rag to git (add to .gitignore if not already present)

# Voyage AI (primary embeddings — voyage-3-large)
VOYAGE_API_KEY=your_voyage_api_key_here

# Anthropic (Claude Opus 4.7 — reconciler, synthesizer, router)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (fallback embeddings at index time only — NOT at query time)
OPENAI_API_KEY=your_openai_api_key_here

# Supabase (pgvector store)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_URL=your_supabase_url_here

# Optional: override default model identifiers
# RAG_EMBEDDING_MODEL=voyage-3-large
# RAG_RECONCILER_MODEL=claude-opus-4-7
# RAG_ROUTER_MODEL=claude-opus-4-7
# RAG_SYNTHESIZER_MODEL=claude-opus-4-7
